# Normalize all text files to LF in the repository (Git stores LF, checks out
# native — Windows users get CRLF locally, Linux/Mac get LF, but the repo is
# always LF). This silences the "LF will be replaced by CRLF" warnings.
* text=auto eol=lf

# Force LF for shell scripts (must be LF to run on Linux/Mac)
*.sh text eol=lf

# Force CRLF for Windows-specific scripts
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary files (never modify)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
